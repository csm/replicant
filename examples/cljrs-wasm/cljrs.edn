;; cljrs project configuration for the Replicant WASM demo.
;;
;; NOTE: the exact cljrs.edn schema stabilized with the wasm CLI in cljrs
;; 0.1.194; treat the keys below as a starting template and reconcile them with
;; `cljrs help` / the cljrs docs for the version you build with.
{:paths ["src"
         ;; Replicant's cljc sources. Adjust the relative path if you vendor or
         ;; depend on Replicant differently.
         "../../src"]

 :deps {;; The Clojure DOM API for wasm targets (cljrs.dom). Provides the
        ;; primitives Replicant's :rust renderer calls.
        cljrs/cljrs-dom {:mvn/version "0.1.195"}}

 :wasm {:entry demo.main/main
        :out "public/demo.wasm"}}
